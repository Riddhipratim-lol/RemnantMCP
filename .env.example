# PostgreSQL Database URL (Source of Truth)
REMNANT_DB_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name

# Qdrant Cloud (Vector Index)
REMNANT_QDRANT_URL=https://your-qdrant-cluster.aws.cloud.qdrant.io
REMNANT_QDRANT_API_KEY=your_qdrant_api_key

# Neo4j Aura (Knowledge Graph)
REMNANT_NEO4J_URL=neo4j+s://your-neo4j-db-id.databases.neo4j.io
REMNANT_NEO4J_USERNAME=neo4j
REMNANT_NEO4J_PASSWORD=your_neo4j_password

# LLM Providers (Gemini Flash Lite)
GEMINI_API_KEY=your_gemini_api_key

# Voyage AI (Embeddings & Reranker)
VOYAGE_API_KEY=your_voyage_api_key

# Local Project Settings
REMNANT_PROJECT_ROOT=.
